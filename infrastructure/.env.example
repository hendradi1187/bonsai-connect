# ============================================================
# PPBI Bonsai Connect — Production Environment Variables
# Salin file ini ke .env lalu isi nilainya.
# JANGAN commit file .env ke git.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=bonsai_user
POSTGRES_PASSWORD=GANTI_PASSWORD_DB_ANDA
POSTGRES_DB=bonsai_db

# --- MinIO Object Storage ---
MINIO_ROOT_USER=GANTI_MINIO_USER
MINIO_ROOT_PASSWORD=GANTI_MINIO_PASSWORD_MIN_8_KARAKTER
# URL MinIO yang bisa diakses dari browser (gunakan IP publik jika tidak ada domain)
MINIO_PUBLIC_URL=http://45.158.126.171:9000

# --- Backend ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_STRING_RANDOM_PANJANG_MIN_64_KARAKTER
JWT_EXPIRES_IN=7d
NODE_ENV=production

# --- CORS (frontend yang diizinkan akses API) ---
CORS_ORIGIN=http://45.158.126.171

# --- Frontend (dipakai saat build: npm run build) ---
VITE_API_BASE_URL=http://45.158.126.171/api
VITE_WS_URL=http://45.158.126.171
